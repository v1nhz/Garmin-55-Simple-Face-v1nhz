<layout id="WatchFace">
    <drawable class="Background" />
    <label id="Battery"         x="center"  y="1"     font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_CENTER" />
    <label id="HoursAndMinutes" x="98"  y="60"  font="Graphics.FONT_NUMBER_MILD" justification="Graphics.TEXT_JUSTIFY_RIGHT"/>    
    <label id="Date"            x="98"      y="96"      font="Graphics.FONT_XTINY"  justification="Graphics.TEXT_JUSTIFY_RIGHT"   />
    <label id="LunarDate"       x="98"     y="120"      font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_RIGHT"  />

    <label id="DayOfTheWeek"    x="center"  y="40"      font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_CENTER"/>
    <label id="HeartRate"       x="center"      y="180"     font="Graphics.FONT_SMALL"      color="Graphics.COLOR_WHITE" justification="Graphics.TEXT_JUSTIFY_LEFT"/>
    <label id="Steps"           x="125"     y="120"     font="Graphics.FONT_XTINY"      color="Graphics.COLOR_WHITE" />
    <label id="Calories"        x="125"     y="96"     font="Graphics.FONT_XTINY"      color="Graphics.COLOR_WHITE" />
    <label id="Title"           x="center"  y="25"      font="Graphics.FONT_TINY"        justification="Graphics.TEXT_JUSTIFY_CENTER"/>
</layout>