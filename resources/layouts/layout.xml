<layout id="WatchFace">
    <drawable class="Background" />
    <label id="Date"            x="20"      y="50"      font="Graphics.FONT_XTINY"     />
    <label id="LunarDate"       x="148"     y="50"      font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_LEFT"  />
    <label id="DayOfTheWeek"    x="center"  y="40"      font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_CENTER"/>
    <label id="HoursAndMinutes" x="center"  y="center"  font="Graphics.FONT_NUMBER_HOT" justification="Graphics.TEXT_JUSTIFY_CENTER"/>    
    <label id="Battery"         x="center"  y="90%"     font="Graphics.FONT_XTINY"      justification="Graphics.TEXT_JUSTIFY_CENTER" />
    <label id="HeartRate"       x="62"      y="148"     font="Graphics.FONT_SMALL"      color="Graphics.COLOR_WHITE" />
    <label id="Steps"           x="125"     y="140"     font="Graphics.FONT_XTINY"      color="Graphics.COLOR_WHITE" />
    <label id="Calories"        x="125"     y="160"     font="Graphics.FONT_XTINY"      color="Graphics.COLOR_WHITE" />
    <label id="Title"           x="center"  y="15"      font="Graphics.FONT_TINY"        justification="Graphics.TEXT_JUSTIFY_CENTER"/>
</layout>